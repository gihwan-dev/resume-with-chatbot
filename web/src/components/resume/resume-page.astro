---
import { render } from "astro:content"
import { Separator } from "@/components/ui/separator"
import Layout from "@/layouts/Layout.astro"
import { resolveResumeContent } from "@/lib/resume/content"
import { RESUME_VARIANT_IDS, RESUME_VARIANT_META, type ResumeVariantId } from "@/lib/resume/variant"
import AwardSection from "@/pages/_sections/award-section.astro"
import BlogSection from "@/pages/_sections/blog-section.astro"
import CertificateSection from "@/pages/_sections/certificate-section.astro"
import EducationSection from "@/pages/_sections/education-section.astro"
import ExperienceSection from "@/pages/_sections/experience-section.astro"
import HeroSection from "@/pages/_sections/hero-section.astro"
import SkillsSection from "@/pages/_sections/skills-section.astro"

interface Props {
  variant: ResumeVariantId
}

const { variant } = Astro.props as Props
const resumeContent = await resolveResumeContent(variant)

const profile = resumeContent.profile
const skillsData = resumeContent.skillsData
const experienceEntries = resumeContent.experienceEntries
const blogPosts = resumeContent.blogPosts
const education = resumeContent.education
const certificates = resumeContent.certificates
const awards = resumeContent.awards
const currentVariant = resumeContent.variant
const variantMeta = RESUME_VARIANT_META[currentVariant]
const pdfDownloadUrl = `/api/resume-pdf?variant=${currentVariant}`

const awardsWithContent = await Promise.all(
  awards.map(async (entry) => {
    const { Content } = await render(entry)
    return { ...entry, Content }
  })
)

const variantLinks = RESUME_VARIANT_IDS.map((id) => ({
  id,
  label: RESUME_VARIANT_META[id].label,
  href: RESUME_VARIANT_META[id].path,
  isActive: id === currentVariant,
}))
---

<Layout
  title={`${profile.name} | ${variantMeta.pageTitle}`}
  description={variantMeta.pageDescription}
  resumeVariant={currentVariant}
>
  <main
    id="main-content"
    tabindex="-1"
    class="container max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8 min-h-screen"
  >
    <HeroSection profile={profile} variantLinks={variantLinks} />

    <div class="mt-4">
      <a
        id="resume-pdf-download-link"
        href={pdfDownloadUrl}
        download
        class="inline-flex items-center justify-center rounded-md border border-resume-border bg-resume-card-bg px-3 py-2 text-sm font-medium text-resume-text-main hover:bg-resume-highlight transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-resume-bg"
        data-ga-event="pdf_download"
        data-ga-file-name={`${profile.name}_이력서`}
        data-ga-resume-variant={currentVariant}
        data-default-label="PDF 다운로드"
        data-loading-label="마크다운 변환 중..."
        aria-busy="false"
      >
        <span class="relative inline-flex items-center justify-center">
          <span data-download-label-sizer class="invisible pointer-events-none" aria-hidden="true">
            PDF 다운로드
          </span>
          <span data-download-label class="absolute inset-0 inline-flex items-center justify-center">
            PDF 다운로드
          </span>
        </span>
      </a>
    </div>

    <Separator className="my-12" />

    <ExperienceSection experiences={experienceEntries} />

    <Separator className="my-12" />

    <BlogSection posts={blogPosts} />

    <Separator className="my-12" />

    <AwardSection awards={awardsWithContent} />

    <Separator className="my-12" />

    <CertificateSection certificates={certificates} />

    <Separator className="my-12" />

    {skillsData && <SkillsSection skills={skillsData} />}

    {education.length > 0 && (
      <>
        <Separator className="my-12" />
        <EducationSection education={education} />
      </>
    )}
  </main>
</Layout>

<script>
  type ResumePageWindow = Window & {
    __resumeAnalyticsClickBound?: boolean
    __resumeSectionObserver?: IntersectionObserver
    gtag?: (command: string, eventName: string, params?: Record<string, string>) => void
  }

  function setupAnalytics() {
    const resumeWindow = window as ResumePageWindow
    const resumeVariant = document.body.dataset.resumeVariant ?? "frontend"
    if (typeof resumeWindow.gtag !== "function") return

    if (!resumeWindow.__resumeAnalyticsClickBound) {
      document.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest("[data-ga-event]") as HTMLElement | null
        if (!target) return

        const eventName = target.dataset.gaEvent
        if (!eventName) return
        const params: Record<string, string> = {}

        for (const [key, value] of Object.entries(target.dataset)) {
          if (key.startsWith("ga") && key !== "gaEvent" && value) {
            const paramKey = key.slice(2).toLowerCase()
            params[paramKey] = value
          }
        }

        if (target.dataset.gaResumeVariant) {
          params.resume_variant = target.dataset.gaResumeVariant
        }

        resumeWindow.gtag?.("event", eventName, params)
      })

      resumeWindow.__resumeAnalyticsClickBound = true
    }

    resumeWindow.__resumeSectionObserver?.disconnect()

    const sections = document.querySelectorAll<HTMLElement>(
      "#profile, #experience, #blog, #awards, #certificates"
    )
    const viewed = new Set<string>()

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !viewed.has(entry.target.id)) {
            viewed.add(entry.target.id)
            resumeWindow.gtag?.("event", "section_view", {
              section_name: entry.target.id,
              resume_variant: resumeVariant,
            })
          }
        }
      },
      { threshold: 0.3 }
    )

    for (const section of sections) {
      observer.observe(section)
    }

    resumeWindow.__resumeSectionObserver = observer
  }

  function parseDownloadFileName(contentDisposition: string | null, fallbackFileName: string): string {
    if (!contentDisposition) return fallbackFileName

    const utf8Match = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i)
    if (utf8Match?.[1]) {
      try {
        return decodeURIComponent(utf8Match[1])
      } catch {
        return utf8Match[1]
      }
    }

    const quotedMatch = contentDisposition.match(/filename="([^"]+)"/i)
    if (quotedMatch?.[1]) {
      return quotedMatch[1]
    }

    const plainMatch = contentDisposition.match(/filename=([^;]+)/i)
    if (plainMatch?.[1]) {
      return plainMatch[1].trim()
    }

    return fallbackFileName
  }

  function setupPdfDownloadLoading() {
    const link = document.getElementById("resume-pdf-download-link")
    if (!(link instanceof HTMLAnchorElement)) return
    if (link.dataset.pdfDownloadBound === "true") return

    const label = link.querySelector<HTMLElement>("[data-download-label]")
    const labelSizer = link.querySelector<HTMLElement>("[data-download-label-sizer]")
    const defaultLabel = link.dataset.defaultLabel ?? "PDF 다운로드"
    const loadingLabel = link.dataset.loadingLabel ?? "다운로드 준비 중..."
    const fileNameBase = link.dataset.gaFileName ?? "resume"
    const fallbackFileName = fileNameBase.endsWith(".pdf") ? fileNameBase : `${fileNameBase}.pdf`
    if (labelSizer) {
      labelSizer.textContent =
        loadingLabel.length >= defaultLabel.length ? loadingLabel : defaultLabel
    }

    const setLoadingState = (loading: boolean) => {
      link.dataset.loading = loading ? "true" : "false"
      link.setAttribute("aria-busy", loading ? "true" : "false")
      link.setAttribute("aria-disabled", loading ? "true" : "false")
      link.classList.toggle("opacity-60", loading)
      link.classList.toggle("cursor-wait", loading)
      if (label) {
        label.textContent = loading ? loadingLabel : defaultLabel
      }
    }

    const onClick = async (event: MouseEvent) => {
      if (link.dataset.loading === "true") {
        event.preventDefault()
        return
      }

      event.preventDefault()
      setLoadingState(true)

      try {
        const response = await fetch(link.href, {
          method: "GET",
          credentials: "same-origin",
        })

        if (!response.ok) {
          throw new Error(`Failed to download PDF: ${response.status}`)
        }

        const blob = await response.blob()
        const fileName = parseDownloadFileName(
          response.headers.get("content-disposition"),
          fallbackFileName
        )
        const blobUrl = URL.createObjectURL(blob)
        const downloadAnchor = document.createElement("a")
        downloadAnchor.href = blobUrl
        downloadAnchor.download = fileName
        document.body.appendChild(downloadAnchor)
        downloadAnchor.click()
        document.body.removeChild(downloadAnchor)
        URL.revokeObjectURL(blobUrl)
      } catch (error) {
        console.error("PDF 다운로드 실패:", error)
      } finally {
        setLoadingState(false)
      }
    }

    link.addEventListener("click", onClick)
    link.dataset.pdfDownloadBound = "true"
  }

  setupAnalytics()
  setupPdfDownloadLoading()
</script>
