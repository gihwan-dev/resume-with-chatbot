---
import { Markdown } from "@astropub/md"
import { normalizeKoreanMarkdown } from "@/lib/markdown/normalize-korean-markdown"

interface ExperienceCaseItem {
  projectId: string
  title: string
  href?: string
  summary?: string
  accomplishments?: string[]
  ctaLabel?: string
}

interface ExperienceEntry {
  data: {
    company: string
    role: string
    dateStart: Date
    dateEnd?: Date
    isCurrent: boolean
    highlights?: string[]
  }
  projects: ExperienceCaseItem[]
}

interface Props {
  experiences: ExperienceEntry[]
}

const { experiences } = Astro.props as Props
const summaryMarkdownClass =
  "[&_p]:m-0 [&_code]:rounded-sm [&_code]:border [&_code]:border-resume-border/70 [&_code]:bg-resume-highlight/60 [&_code]:px-1 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[0.85em] [&_pre]:mt-2 [&_pre]:overflow-x-auto [&_pre]:rounded-sm [&_pre]:border [&_pre]:border-resume-border/70 [&_pre]:bg-resume-highlight/40 [&_pre]:p-3 [&_pre]:text-xs [&_pre_code]:border-0 [&_pre_code]:bg-transparent [&_pre_code]:p-0"
---

<section
  id="experience"
  class="mb-12 relative"
>
  <h2 class="text-2xl font-bold text-resume-text-main mb-8 tracking-tight">
    Experience
  </h2>
  <div>
    {
      experiences.map((entry: ExperienceEntry, index: number) => (
        <div class="relative pl-8 pb-12 last:pb-0">
          <div
            class:list={[
              "absolute left-[7px] w-[2px] bg-resume-primary/30",
              index === 0 ? "top-1.5" : "top-0",
              index === experiences.length - 1 ? "h-3.5" : "bottom-0",
            ]}
          />
          <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-resume-primary ring-4 ring-resume-bg z-10" />

          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-2">
            <h3 class="text-xl font-bold text-resume-text-heading font-heading">
              {entry.data.role}
            </h3>
            <span class="text-sm font-mono text-resume-text-muted">
              {entry.data.dateStart.toLocaleDateString("en-US", {
                month: "short",
                year: "numeric",
              })}
              {(entry.data.isCurrent || entry.data.dateEnd) && (
                <>
                  {" - "}
                  {entry.data.isCurrent
                    ? "Present"
                    : entry.data.dateEnd?.toLocaleDateString("en-US", {
                        month: "short",
                        year: "numeric",
                      })}
                </>
              )}
            </span>
          </div>

          <div class="mb-4">
            <span class="text-lg font-medium text-resume-primary">
              {entry.data.company}
            </span>
          </div>

          {entry.projects.length > 0 ? (
            <div class="space-y-4">
              {entry.projects.map((project) => (
                <article
                  class="bg-resume-card-bg rounded-sm border border-resume-border p-5 transition-all duration-300 hover:border-resume-primary/50 hover:bg-resume-highlight/30"
                >
                  <h4 class="text-lg font-semibold text-resume-text-heading">{project.title}</h4>
                  {project.summary && (
                    <div
                      data-experience-project-summary
                      class:list={[
                        "mt-1.5 text-sm leading-relaxed text-resume-text-main/90",
                        summaryMarkdownClass,
                      ]}
                    >
                      <Markdown of={normalizeKoreanMarkdown(project.summary)} />
                    </div>
                  )}

                  {project.accomplishments && project.accomplishments.length > 0 && (
                    <ul class="mt-5 space-y-2.5">
                      {project.accomplishments.map((accomplishment) => (
                        <li class="flex items-start gap-2.5">
                          <span
                            aria-hidden="true"
                            class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-resume-primary/70"
                          />
                          <div class="text-sm leading-relaxed text-resume-text-main/90 [&_p]:m-0">
                            <Markdown of={normalizeKoreanMarkdown(accomplishment)} />
                          </div>
                        </li>
                      ))}
                    </ul>
                  )}

                  {project.href && (
                    <div class="mt-6 border-t border-resume-border/70 pt-4">
                      <a
                        href={project.href}
                        class="group/btn inline-flex cursor-pointer items-center gap-1.5 rounded-sm text-sm font-semibold text-resume-primary underline-offset-4 transition-colors duration-200 hover:text-resume-secondary hover:underline focus-visible:text-resume-secondary focus-visible:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-resume-card-bg"
                        data-ga-event="project_portfolio_click"
                        data-ga-project={project.title}
                      >
                        {project.ctaLabel ?? "상세 케이스 스터디 보기"}
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          xmlns="http://www.w3.org/2000/svg"
                          width="16"
                          height="16"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="h-4 w-4 opacity-90 transition-all duration-200 group-hover/btn:translate-x-0.5 group-hover/btn:opacity-100 group-focus-visible/btn:translate-x-0.5 group-focus-visible/btn:opacity-100"
                        >
                          <path d="M5 12h14" />
                          <path d="m12 5 7 7-7 7" />
                        </svg>
                      </a>
                    </div>
                  )}
                </article>
              ))}
            </div>
          ) : (
            entry.data.highlights &&
            entry.data.highlights.length > 0 && (
              <div class="space-y-2 text-sm leading-relaxed text-resume-text-main/90">
                {entry.data.highlights.map((highlight) => (
                  <div class="[&_p]:m-0">
                    <Markdown of={normalizeKoreanMarkdown(highlight)} />
                  </div>
                ))}
              </div>
            )
          )}
        </div>
      ))
    }
  </div>
</section>
